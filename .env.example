# URL del backend para llamadas server-side (SSR / RSC / route handlers).
# Server-only — NO se bakea al bundle del browser.
# En Railway, seteá esto al private domain del backend para evitar el hop
# público y los cold starts del edge:
#   API_URL=http://backend-kansaco.railway.internal:PORT/api
API_URL=http://localhost:3001/api

# Fallback para llamadas server-side cuando API_URL no está seteada.
# El browser ya no la usa — todas las llamadas client-side van por
# `/api/*` (proxy en app/api/[...path]/route.ts).
# Si la sacás, el route handler también cae a localhost en dev.
NEXT_PUBLIC_API_URL=http://localhost:3001/api
